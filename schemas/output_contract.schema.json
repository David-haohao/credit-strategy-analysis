{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Credit strategy stage output contract",
  "type": "object",
  "required": ["output_contract_version", "stage_id", "artifacts"],
  "properties": {
    "output_contract_version": {"const": "1.2"},
    "stage_id": {"type": "string", "enum": ["00", "01", "02", "03", "04"]},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_name", "relative_path", "status", "sha256", "report_eligible"],
        "properties": {
          "artifact_name": {"type": "string"},
          "relative_path": {"type": "string", "pattern": "^(00_data_contract|01_rule_mining|02_rule_combination|03_strategy_evaluation|04_final_report)/"},
          "status": {"enum": ["generated", "not_applicable", "not_available", "failed"]},
          "reason": {"type": ["string", "null"]},
          "row_count": {"type": ["integer", "null"], "minimum": 0},
          "columns": {"type": ["array", "null"], "items": {"type": "string"}},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "report_eligible": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
