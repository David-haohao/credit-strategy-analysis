{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Credit Strategy Configuration",
  "type": "object",
  "required": ["strategy_type"],
  "properties": {
    "strategy_type": {"enum": ["rule", "score_cutoff", "score_rule", "routing"]},
    "score_cutoff": {"type": ["number", "null"]},
    "score_direction": {"enum": ["high_score_high_risk", "high_score_low_risk", null]},
    "route_policies": {"type": "object"},
    "rule_config_path": {"type": ["string", "null"]}
  }
}
