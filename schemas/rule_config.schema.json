{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Credit Strategy Rule Configuration",
  "type": "object",
  "required": ["rules", "execution"],
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "name", "condition"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "condition": {
            "type": "object",
            "required": ["field", "op", "value"],
            "properties": {
              "field": {"type": "string"},
              "op": {"enum": [">", ">=", "<", "<=", "==", "!=", "in", "not_in", "is_null"]},
              "value": {}
            }
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "required": ["mode", "default_approval"],
      "properties": {
        "mode": {"enum": ["independent", "sequential", "and", "or", "routing"]},
        "default_approval": {"enum": [0, 1]}
      }
    }
  }
}
