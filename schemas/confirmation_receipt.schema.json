{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Credit Strategy User Confirmation Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "source",
    "confirmed",
    "product_form",
    "repayment_type",
    "scenario",
    "task_type",
    "field_mapping",
    "analysis_grain",
    "label",
    "amount_metric"
  ],
  "properties": {
    "schema_version": {"const": "0.1"},
    "source": {"const": "user_interaction"},
    "confirmed": {"const": true},
    "product_form": {"type": "string"},
    "repayment_type": {"type": "string"},
    "scenario": {"type": "string"},
    "task_type": {"type": "string"},
    "field_mapping": {
      "type": "object",
      "required": ["confirmed"],
      "properties": {"confirmed": {"const": true}}
    },
    "analysis_grain": {
      "type": "object",
      "required": ["grain", "id_cols"],
      "properties": {
        "grain": {"type": "string"},
        "id_cols": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "aggregation_rule": {"type": ["string", "null"]}
      }
    },
    "label": {"type": "object"},
    "amount_metric": {"type": "object"}
  },
  "allOf": [
    {
      "if": {"properties": {"task_type": {"const": "rule_combination"}}},
      "then": {
        "required": ["rule_combination"],
        "properties": {
          "rule_combination": {
            "type": "object",
            "required": ["top_n", "ranking_metric", "execution_mode"],
            "properties": {
              "top_n": {"type": "integer", "minimum": 1},
              "ranking_metric": {"const": "lift"},
              "execution_mode": {"const": "sequential_reject"}
            }
          }
        }
      }
    }
  ]
}
