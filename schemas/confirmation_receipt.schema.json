{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "信贷规则策略分析用户确认凭证",
  "type": "object",
  "required": [
    "schema_version", "source", "confirmed", "product_form", "repayment_type",
    "scenario", "task_type", "field_mapping", "analysis_grain", "label", "amount_metric"
  ],
  "properties": {
    "schema_version": {"const": "0.1"},
    "source": {"const": "user_interaction"},
    "confirmed": {"const": true},
    "product_form": {"type": "string", "minLength": 1},
    "repayment_type": {"type": "string", "minLength": 1},
    "scenario": {"type": "string", "minLength": 1},
    "task_type": {
      "enum": ["rule_mining", "rule_combination", "strategy_evaluation", "final_report"]
    },
    "field_mapping": {
      "type": "object",
      "required": ["confirmed"],
      "properties": {"confirmed": {"const": true}}
    },
    "analysis_grain": {
      "type": "object",
      "required": ["grain", "id_cols", "aggregation_rule"],
      "properties": {
        "grain": {"type": "string", "minLength": 1},
        "id_cols": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "aggregation_rule": {"type": ["string", "null"]}
      }
    },
    "label": {"type": "object"},
    "amount_metric": {"type": "object"}
  }
}
