<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    body { color: #18212f; font: 14px/1.55 -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 0 auto; max-width: 1120px; padding: 32px; }
    h1, h2 { color: #12355b; } .note { background: #eef5fb; border-left: 4px solid #2674b9; padding: 12px 16px; }
    table { border-collapse: collapse; margin: 14px 0 28px; width: 100%; } th, td { border: 1px solid #d7dee7; padding: 8px; text-align: left; vertical-align: top; }
    th { background: #f4f7fa; } code { overflow-wrap: anywhere; } .status-generated { color: #176b3a; } .status-not { color: #925b00; }
  </style>
</head>
<body>
  <h1>{{ title }}</h1>
  <p class="note"><strong>报告范围：</strong>{{ scope }}<br><strong>限制：</strong>本报告只读取已登记、哈希校验通过的阶段聚合产物；不读取原始数据、不重算规则或策略指标。若产物状态为“未适用”或“不可用”，不将其解释为风险结论。直接观测、估计、不可观测结果必须分开展示。</p>

  <section id="chapters">
    <h2>固定报告章节</h2>
    <table>
      <thead><tr><th>章节</th><th>展示原则</th></tr></thead>
      <tbody>
      {% for chapter_id, chapter_title in chapters.items() %}
        <tr><td>{{ chapter_title }}</td><td>仅展示阶段 00-03 已登记且哈希一致的聚合指标；缺失来源时显示“未提供/不可用”，不在报告阶段补算。</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  {% for stage_id, section_title in sections.items() %}
  <section id="stage-{{ stage_id }}">
    <h2>来源索引 · {{ stage_id }} · {{ section_title }}</h2>
    <table>
      <thead><tr><th>产物</th><th>状态</th><th>固定路径</th><th>SHA-256</th><th>限制/原因</th></tr></thead>
      <tbody>
      {% for row in source_rows if row.stage_id == stage_id %}
        <tr><td>{{ row.artifact_name }}</td><td class="status-{{ row.artifact_status.split('_')[0] }}">{{ row.artifact_status }}</td><td><code>{{ row.relative_path }}</code></td><td><code>{{ row.sha256 }}</code></td><td>{{ row.limitation }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endfor %}

  <section id="validation">
    <h2>报告输入校验</h2>
    <table><thead><tr><th>检查项</th><th>状态</th><th>说明</th></tr></thead><tbody>
    {% for row in validations %}<tr><td>{{ row.check_name }}</td><td>{{ row.status }}</td><td>{{ row.details }}</td></tr>{% endfor %}
    </tbody></table>
  </section>
</body>
</html>
